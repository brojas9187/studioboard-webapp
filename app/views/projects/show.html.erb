<section class="space-y-8">
  <div class="card-panel p-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <%= link_to t("app.actions.back_to_projects_arrow"), projects_path, class: "text-sm font-medium text-slate-500 hover:text-slate-900" %>
        <p class="kicker mt-5"><%= t(".kicker") %></p>
        <h1 class="mt-2 text-4xl"><%= @project.name %></h1>
        <p class="mt-4 max-w-3xl text-lg text-slate-600"><%= @project.description.presence || t("app.empty_states.no_description") %></p>
      </div>

      <div class="flex flex-wrap gap-3">
        <% if project_management_allowed? %>
          <%= link_to t("app.actions.edit_project"), edit_project_path(@project), class: "btn-secondary" %>
        <% end %>
        <% if current_membership&.owner? %>
          <%= button_to t("app.actions.delete_project"), project_path(@project), method: :delete, class: "btn-danger", form: { data: { turbo_confirm: t(".delete_confirm", name: @project.name) } } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.92fr_1.08fr] xl:items-start">
    <div id="task_form">
      <%= render "tasks/form", project: @project, task: @form_task, member_options: @member_options %>
    </div>

    <div id="tasks_panel">
      <%= render "tasks/panel", project: @project, tasks: @tasks %>
    </div>
  </div>
</section>
