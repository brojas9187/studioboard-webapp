<div class="card-panel p-8">
  <div class="space-y-6">
    <div>
      <p class="kicker"><%= title_kicker %></p>
      <h1 class="mt-2 text-4xl"><%= title_text %></h1>
      <p class="mt-3 max-w-2xl text-slate-600"><%= title_copy %></p>
    </div>

    <%= render "shared/form_errors", resource: project %>

    <%= form_with model: project, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :name, t(".name_label") %>
        <%= form.text_field :name, class: "input-field", placeholder: t(".name_placeholder") %>
      </div>

      <div>
        <%= form.label :description %>
        <%= form.text_area :description, class: "textarea-field", placeholder: t(".description_placeholder") %>
      </div>

      <div class="flex flex-wrap items-center gap-3">
        <%= form.submit submit_label, class: "btn-primary" %>
        <%= link_to t("app.actions.back_to_projects"), projects_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
