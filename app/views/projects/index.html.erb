<section class="space-y-8">
  <div class="card-panel p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="kicker"><%= t(".header.kicker") %></p>
        <h1 class="mt-3 text-4xl"><%= t(".header.title") %></h1>
        <p class="mt-3 max-w-3xl text-slate-600"><%= t(".header.description") %></p>
      </div>

      <div class="flex flex-wrap gap-3">
        <% if project_management_allowed? %>
          <%= link_to t("app.actions.new_project"), new_project_path, class: "btn-primary" %>
        <% end %>
        <% if current_membership&.owner? %>
          <%= link_to t("app.navigation.billing"), billing_path, class: "btn-secondary" %>
        <% end %>
      </div>
    </div>
  </div>

  <% if current_organization.free? %>
    <div class="card-panel border border-amber-200 bg-amber-50/80 p-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-amber-900"><%= t(".free_plan.kicker") %></p>
      <p class="mt-2 text-sm text-amber-900"><%= t(".free_plan.body", count: current_organization.projects.count) %></p>
      <p class="mt-1 text-sm text-amber-900"><%= current_membership&.owner? ? t(".free_plan.owner_hint") : t(".free_plan.member_hint") %></p>
    </div>
  <% end %>

  <div class="grid gap-4">
    <% if @projects.any? %>
      <% @projects.each do |project| %>
        <div class="card-panel p-6">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <p class="kicker"><%= t(".project_card.created_by", name: project.creator.display_name) %></p>
              <h2 class="mt-2 text-2xl"><%= project.name %></h2>
              <p class="mt-3 max-w-3xl text-slate-600"><%= project.description.presence || t("app.empty_states.no_description") %></p>
              <p class="mt-4 text-sm text-slate-500"><%= t(".project_card.updated_ago", time: time_ago_in_words(project.updated_at)) %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <%= link_to t("app.actions.open"), project_path(project), class: "btn-secondary" %>
              <% if project_management_allowed? %>
                <%= link_to t("app.actions.edit"), edit_project_path(project), class: "btn-secondary" %>
              <% end %>
              <% if current_membership&.owner? %>
                <%= button_to t("app.actions.delete"), project_path(project), method: :delete, class: "btn-danger", form: { data: { turbo_confirm: t(".project_card.delete_confirm", name: project.name) } } %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="card-panel p-8 text-center">
        <p class="text-sm uppercase tracking-[0.22em] text-slate-500"><%= t(".empty.kicker") %></p>
        <h2 class="mt-3 text-3xl"><%= t(".empty.title") %></h2>
        <p class="mt-3 text-slate-600"><%= t(".empty.description") %></p>
        <% if project_management_allowed? %>
          <div class="mt-6">
            <%= link_to t("app.actions.create_project"), new_project_path, class: "btn-primary" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
