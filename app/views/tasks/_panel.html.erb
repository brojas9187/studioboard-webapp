<div class="card-panel p-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <p class="kicker"><%= t(".kicker") %></p>
      <h2 class="mt-2 text-2xl"><%= t(".title") %></h2>
    </div>

    <% completed_count = tasks.count(&:completed?) %>
    <% open_count = tasks.size - completed_count %>
    <div class="flex flex-wrap gap-2">
      <span class="pill bg-amber-100 text-amber-900"><%= t(".counts.open", count: open_count) %></span>
      <span class="pill bg-emerald-100 text-emerald-900"><%= t(".counts.done", count: completed_count) %></span>
    </div>
  </div>

  <div class="mt-6 space-y-3">
    <% if tasks.any? %>
      <% tasks.each do |task| %>
        <article class="rounded-3xl border border-slate-200 p-5 transition hover:border-slate-300 hover:bg-slate-50/70">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="text-xl"><%= task.title %></h3>
                <span class="pill <%= task_status_badge_classes(task) %>"><%= task.completed? ? t("app.task_status.done") : t("app.task_status.pending") %></span>
              </div>
              <p class="text-sm text-slate-600"><%= task.description.presence || t(".no_extra_notes") %></p>
              <p class="text-xs uppercase tracking-[0.2em] text-slate-500"><%= t(".assignment", assignee: task.assignee.display_name, creator: task.creator.display_name) %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <% if task.manageable_by?(current_membership) %>
                <%= button_to(task.completed? ? t("app.actions.mark_pending") : t("app.actions.mark_done"),
                              toggle_project_task_path(project, task),
                              method: :patch,
                              class: "btn-secondary",
                              form: { data: { turbo_stream: true } }) %>
                <%= button_to t("app.actions.delete"),
                              project_task_path(project, task),
                              method: :delete,
                              class: "btn-danger",
                              form: { data: { turbo_confirm: t(".delete_confirm", title: task.title), turbo_stream: true } } %>
              <% else %>
                <span class="text-sm text-slate-500"><%= t(".read_only") %></span>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    <% else %>
      <div class="card-muted p-8 text-center">
        <p class="text-sm uppercase tracking-[0.22em] text-slate-500"><%= t(".empty.kicker") %></p>
        <h3 class="mt-3 text-2xl"><%= t(".empty.title") %></h3>
        <p class="mt-3 text-sm text-slate-600"><%= t(".empty.description") %></p>
      </div>
    <% end %>
  </div>
</div>
