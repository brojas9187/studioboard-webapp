<section class="grid gap-8 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
  <div class="space-y-8">
    <span class="pill bg-slate-900 text-white"><%= t(".hero_badge") %></span>

    <div class="space-y-5">
      <p class="kicker"><%= t("app.name") %></p>
      <h1 class="text-5xl sm:text-6xl"><%= t(".title") %></h1>
      <p class="max-w-2xl text-lg text-slate-600"><%= t(".description") %></p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to t("app.actions.create_your_account"), new_registration_path, class: "btn-primary" %>
      <%= link_to t("app.actions.sign_in"), new_session_path, class: "btn-secondary" %>
    </div>

    <div class="grid gap-4 sm:grid-cols-3">
      <div class="card-panel p-5">
        <p class="kicker"><%= t(".cards.tenancy.kicker") %></p>
        <h2 class="mt-3 text-xl"><%= t(".cards.tenancy.title") %></h2>
        <p class="mt-2 text-sm text-slate-600"><%= t(".cards.tenancy.body") %></p>
      </div>
      <div class="card-panel p-5">
        <p class="kicker"><%= t(".cards.limits.kicker") %></p>
        <h2 class="mt-3 text-xl"><%= t(".cards.limits.title") %></h2>
        <p class="mt-2 text-sm text-slate-600"><%= t(".cards.limits.body") %></p>
      </div>
      <div class="card-panel p-5">
        <p class="kicker"><%= t(".cards.hotwire.kicker") %></p>
        <h2 class="mt-3 text-xl"><%= t(".cards.hotwire.title") %></h2>
        <p class="mt-2 text-sm text-slate-600"><%= t(".cards.hotwire.body") %></p>
      </div>
    </div>
  </div>

  <div class="card-panel overflow-hidden p-8">
    <div class="rounded-[2rem] bg-slate-950 p-7 text-white">
      <p class="kicker !text-slate-300"><%= t(".mvp.kicker") %></p>
      <h2 class="mt-4 text-3xl text-white"><%= t(".mvp.title") %></h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="rounded-3xl bg-white/10 p-4">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-300"><%= t(".mvp.items.auth.label") %></p>
          <p class="mt-2 text-sm text-slate-100"><%= t(".mvp.items.auth.body") %></p>
        </div>
        <div class="rounded-3xl bg-white/10 p-4">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-300"><%= t(".mvp.items.projects.label") %></p>
          <p class="mt-2 text-sm text-slate-100"><%= t(".mvp.items.projects.body") %></p>
        </div>
        <div class="rounded-3xl bg-white/10 p-4">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-300"><%= t(".mvp.items.tasks.label") %></p>
          <p class="mt-2 text-sm text-slate-100"><%= t(".mvp.items.tasks.body") %></p>
        </div>
        <div class="rounded-3xl bg-white/10 p-4">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-300"><%= t(".mvp.items.billing.label") %></p>
          <p class="mt-2 text-sm text-slate-100"><%= t(".mvp.items.billing.body") %></p>
        </div>
      </div>
    </div>
  </div>
</section>
